// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider              = "prisma-client"
  output                = "../generated/prisma"
  importFileExtension   = "ts"
}

datasource db {
  provider = "postgresql"
}

model rooms {
  id           String     @id
  startDate    DateTime   @default(now())
  active       Boolean    @default(false)
  finished     Boolean?   @default(false)
  timeToAnswer Int?
  maxHearts    Int        @default(1)
  host         String?
  lastAnswers  String?    @default("")
  playerLists  Json[]
  kickedPlayers String[]   @default([])
  startPlayer  Json?
  nextPlayer   Json?
  answerList   String[]
  hideAnswer   Boolean?   @default(false)
  hideHeart     Boolean?   @default(false)
  giveUpMode   String?    @default("random")
  winner       Json?
  messages     messages[]
}

model messages {
  id         Int      @id @default(autoincrement())
  room       rooms    @relation(fields: [roomId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  roomId     String
  userId     String
  name       String
  image      String
  message    String   @db.VarChar(150)
  created_at DateTime @default(now())
}

model words {
  id   Int    @id @default(autoincrement())
  name String
}
